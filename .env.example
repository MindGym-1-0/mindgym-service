# Copy to `.env` locally. Never commit secrets.

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=True

# CORS Configuration
FRONTEND_URL=http://localhost:3000
# Optional: comma-separated origins, or "*" for dev (cookies won't work with "*" + credentials).
# CORS_ORIGINS=http://localhost:3000

# Supabase Configuration
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_KEY=your-service-role-key
SUPABASE_ONBOARDING_TABLE=onboarding
INTERNAL_CRON_SECRET=

# Gemini
GEMINI_API_KEY=

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-2024-11-20

# ElevenLabs
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=   # Set after voice selection testing — see docs/superpowers/specs/2026-06-05-elevenlabs-implementation-plan.md
